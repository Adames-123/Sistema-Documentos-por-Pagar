@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    @model IEnumerable<Sistema_Documentos_por_Pagar.Models.Proveedor>

    <h2>Proveedores</h2>

    <a asp-action="Create" class="btn btn-primary">Nuevo Proveedor</a>

    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Tipo Persona</th>
                <th>Cedula/RNC</th>
                <th>Balance</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.TipoPersona</td>
                    <td>@item.CedulaRNC</td>
                    <td>@item.Balance</td>
                    <td>@item.Estado</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IdProveedor">Editar</a> |
                        <a asp-action="Details" asp-route-id="@item.IdProveedor">Detalles</a> |
                        <a asp-action="Delete" asp-route-id="@item.IdProveedor">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
